# ============================================================
# Tableau Multi-Agent System — .env.template
# INSTRUCTIONS:
#   1. Copy this file to .env  (cp .env.template .env)
#   2. Fill in every value below
#   3. NEVER commit .env to git — it is in .gitignore
# ============================================================

# ------------------------------------------------------------
# ANTHROPIC (Claude)
# Get from: https://console.anthropic.com/settings/keys
# ------------------------------------------------------------
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ------------------------------------------------------------
# GOOGLE (Gemini)
# Get from: https://aistudio.google.com/app/apikey
# ------------------------------------------------------------
GOOGLE_API_KEY=your_google_gemini_api_key_here

# ------------------------------------------------------------
# TABLEAU CLOUD
# PAT: Tableau Cloud → My Account Settings → Personal Access Tokens
# Site ID: the slug in your Tableau Cloud URL
#   e.g. https://10ax.online.tableau.com/#/site/YOURSITE → YOURSITE
# ------------------------------------------------------------
TABLEAU_SERVER_URL=https://10ax.online.tableau.com
TABLEAU_SITE_ID=your_site_id
TABLEAU_PAT_NAME=your_pat_name
TABLEAU_PAT_SECRET=your_pat_secret
TABLEAU_API_VERSION=3.21
TABLEAU_TARGET_PROJECT=Default

# ------------------------------------------------------------
# SNOWFLAKE
# Account: find in Snowflake URL → account.snowflakecomputing.com
# Auth: USERNAME_PASSWORD | OAUTH | KEY_PAIR
# ------------------------------------------------------------
SNOWFLAKE_ACCOUNT=your_account.snowflakecomputing.com
SNOWFLAKE_DATABASE=your_database
SNOWFLAKE_SCHEMA=PUBLIC
SNOWFLAKE_WAREHOUSE=your_warehouse
SNOWFLAKE_ROLE=your_role
SNOWFLAKE_USER=your_username
SNOWFLAKE_PASSWORD=your_password

# For OAuth (leave blank if using Username/Password)
SNOWFLAKE_OAUTH_TOKEN=

# For Key-Pair auth (leave blank if using Username/Password)
SNOWFLAKE_PRIVATE_KEY_PATH=
SNOWFLAKE_PRIVATE_KEY_PASSPHRASE=

# ------------------------------------------------------------
# SYSTEM
# ------------------------------------------------------------
ENVIRONMENT=dev
LOG_LEVEL=INFO
STATE_DB_PATH=state/state.db
